# Streamlit secrets (local or hosted).
#
# 1. Copy this file to `secrets.toml` in this same directory:
#    granite-forecasting-tool/.streamlit/secrets.toml
# 2. Do not commit `secrets.toml` (it is listed in .gitignore).
#
# Use a Hugging Face *read* token if Hub rate limits or gated models block downloads.
# The app does not read this key until you add `st.secrets["HF_TOKEN"]` (or similar)
# to your code paths, or you rely on the environment variables documented in README.md.
#
# HF_TOKEN = "hf_..."
